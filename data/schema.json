{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventLive Program Document",
  "type": "object",
  "additionalProperties": false,
  "required": ["program", "sessions"],
  "properties": {
    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "program_title",
        "organizer_name",
        "venue",
        "city",
        "event_start",
        "event_end",
        "updated_at"
      ],
      "properties": {
        "program_title": { "type": "string", "minLength": 1 },
        "organizer_name": { "type": "string", "minLength": 1 },
        "logo_text": { "type": "string" },
        "organizer_display_name": { "type": "string" },
        "primary_label": { "type": "string" },
        "support_contact": { "type": "string" },
        "footer_note": { "type": "string" },
        "venue": { "type": "string", "minLength": 1 },
        "city": { "type": "string", "minLength": 1 },
        "event_start": { "type": "string", "format": "date-time" },
        "event_end": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source",
          "day_label",
          "session_title",
          "session_type",
          "track",
          "speaker",
          "room",
          "start_at",
          "end_at",
          "status",
          "updated_at"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "day_label": { "type": "string", "minLength": 1 },
          "session_title": { "type": "string", "minLength": 1 },
          "session_type": {
            "type": "string",
            "enum": ["keynote", "panel", "workshop", "talk", "break", "networking", "ceremony", "other"]
          },
          "track": { "type": "string", "minLength": 1 },
          "speaker": { "type": "string", "minLength": 1 },
          "moderator": { "type": "string" },
          "start_at": { "type": "string", "format": "date-time" },
          "end_at": { "type": "string", "format": "date-time" },
          "room": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["draft", "scheduled", "live", "completed", "cancelled"]
          },
          "language": {
            "type": "string",
            "enum": ["ar", "en", "bilingual"]
          },
          "audience": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
